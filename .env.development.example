# ============================================================
# Development Environment Configuration
# ============================================================
# 复制此文件为 .env.development 并填写实际值
# cp .env.development.example .env.development

# VLESS + Reality (多用户，逗号分隔)
# 示例: VLESS_UUIDS=uuid1,uuid2,uuid3
VLESS_UUIDS=your-uuid-1,your-uuid-2

REALITY_PRIVATE_KEY=your-dev-private-key
REALITY_PUBLIC_KEY=your-dev-public-key
REALITY_SHORT_ID=your-short-id

# Hysteria2 (多用户，逗号分隔)
# 示例: H2_PASSWORDS=pass1,pass2,pass3
H2_PASSWORDS=your-password-1,your-password-2
