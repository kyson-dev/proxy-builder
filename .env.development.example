# ============================================================
# Development Environment Configuration (Simplified)
# ============================================================
# 复制此文件为 .env.development 并填写实际值
# cp .env.development.example .env.development

# VLESS + Reality
VLESS_UUID=your-dev-uuid
REALITY_PRIVATE_KEY=your-dev-private-key
REALITY_PUBLIC_KEY=your-dev-public-key
REALITY_SHORT_ID=your-short-id

# Hysteria2 (使用自签名证书)
H2_PASSWORD=your-dev-h2-password
