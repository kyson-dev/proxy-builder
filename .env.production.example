# ============================================================
# Production Environment Configuration
# ============================================================
# 复制此文件为 .env.production 并填写实际值
# cp .env.production.example .env.production

# 域名配置
DOMAIN=kyson.site
EMAIL=admin@kyson.site

# VLESS + Reality
VLESS_UUID=your-production-uuid
REALITY_PRIVATE_KEY=your-production-private-key
REALITY_PUBLIC_KEY=your-production-public-key
REALITY_SHORT_ID=your-short-id

# Hysteria2
H2_PASSWORD=your-production-h2-password

# TUIC
TUIC_UUID=your-production-tuic-uuid
TUIC_PASSWORD=your-production-tuic-password