# ============================================================
# Production Environment Configuration (Simplified)
# ============================================================
# 复制此文件为 .env.production 并填写实际值
# cp .env.production.example .env.production

# VLESS + Reality
VLESS_UUID=your-prod-uuid
REALITY_PRIVATE_KEY=your-prod-private-key
REALITY_PUBLIC_KEY=your-prod-public-key
REALITY_SHORT_ID=your-short-id

# Hysteria2 (使用自签名证书)
H2_PASSWORD=your-prod-h2-password