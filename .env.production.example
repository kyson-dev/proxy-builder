# Sing-box REALITY 配置底层参数 (必需)
# 可以使用 `make reality-key` 和 `make short-id` 生成
# 支持多个 Short ID，请使用逗号分隔 (例如: a1b2c3d4,5a6b7c8d)
REALITY_PRIVATE_KEY=
REALITY_PUBLIC_KEY=
REALITY_SHORT_ID=
# 伪装目标网站，必须支持 TLS 1.3 且不禁止外部握手，例如:
REALITY_DEST=www.microsoft.com:443

# 数据根目录（可选，默认 ~/data）
# DATA_ROOT=${HOME}/data
