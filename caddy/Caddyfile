# ==============================================================================
# Caddy 反向代理配置 - HTTPS
# 
# 说明:
# - Caddy 自动在 2095 和 2096 端口上启用 HTTPS
# - 自动申请和续期 Let's Encrypt 证书
# - 不监听 443 端口，避免与 S-UI 的代理流量冲突
# - 访问: https://your-domain.com:2095/app/
# ==============================================================================

# Web 管理面板 - HTTPS on port 2095
{$PANEL_DOMAIN}:2095 {
    reverse_proxy s-ui:2095
    
    # 访问日志
    log {
        output file /data/caddy/access-panel.log
        format json
    }
}

# 订阅服务 - HTTPS on port 2096
{$PANEL_DOMAIN}:2096 {
    reverse_proxy s-ui:2096
    
    # 访问日志
    log {
        output file /data/caddy/access-sub.log
        format json
    }
}
