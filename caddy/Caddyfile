# ==============================================================================
# Caddy 反向代理配置 - HTTP (临时)
# 
# 说明:
# - 使用 HTTP 避免 Caddy 尝试监听 443 端口
# - 2095 和 2096 端口使用 HTTP 协议
# - S-UI 的 443 端口专门用于代理流量
# - 访问: http://your-domain.com:2095/app/
# 
# TODO: 配置 HTTPS 需要使用自签名证书或其他方式，避免 Caddy 自动监听 443
# ==============================================================================

# 全局选项
{
    # 完全禁用自动 HTTPS
    auto_https off
}

# Web 管理面板 - HTTP on port 2095
http://{$PANEL_DOMAIN}:2095 {
    reverse_proxy s-ui:2095
    
    # 访问日志
    log {
        output file /data/caddy/access-panel.log
        format json
    }
}

# 订阅服务 - HTTP on port 2096
http://{$PANEL_DOMAIN}:2096 {
    reverse_proxy s-ui:2096
    
    # 访问日志
    log {
        output file /data/caddy/access-sub.log
        format json
    }
}
